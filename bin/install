#!/bin/zsh

# Install homebrew packages
brew update
brew install autojump figlet fzf ripgrep vim tmux vale

# Pull or update agent skills submodule
if ! git submodule status agent-skills  >/dev/null 2>&1; then
  git submodule add git@github.com:jwworth/agent-skills
else
  cd agent-skills
  git checkout main
  git pull
  cd ..
fi

# Symlink each dotfile
find . -mindepth 1 -maxdepth 1 -name ".*" ! -name ".git" ! -name "agent-skills" -exec ln -svf "$(pwd)/{}" ~ \;

# Symlink project skills for global agent discovery
skills_source_dir="$(pwd)/agent-skills/skills"
skills_target_dir="$HOME/.agents/skills"
mkdir -p "$skills_target_dir"

if [ -d "$skills_source_dir" ]; then
  for skill_path in "$skills_source_dir"/*; do
    [ -e "$skill_path" ] || continue
    ln -sfn "$skill_path" "$skills_target_dir/$(basename "$skill_path")"
  done
else
  echo "No project skills directory found at $skills_source_dir; skipping skills symlinks."
fi
